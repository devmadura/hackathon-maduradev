---
// Timeline.astro
const milestones = [
  {
    date: "29 Juni 2026",
    hash: "6e2a1fb",
    branch: "main",
    title: "Pendaftaran Dibuka",
    description: "Pendaftaran dibuka di MauKuliah. CBT screening aktif. Isi formulir dan kerjakan tes untuk bergabung. dan jangan lupa menggunakan kode referral: MADURADEV",
    author: "admin <semesta@sevima.com>",
    status: "MERGED",
  },
  {
    date: "18 July 2026",
    hash: "7f1b2cc",
    branch: "main",
    title: "Penutupan Pendaftaran",
    description: "Cutoff pendaftaran + penutupan CBT. Rekap CBT & seleksi peserta hackathon per kota.",
    author: "admin <semesta@sevima.com>",
    status: "PENDING",
  },
  {
    date: "5 – 20 September 2026",
    hash: "8c3d4ee",
    branch: "feature/local-sprint",
    title: "Pelaksanaan Hackathon",
    description: "Hackathon dilaksanakan secara offline/hybrid di setiap kota regional yang ditunjuk.",
    author: "local-dev <madura@madura.dev>",
    status: "STAGED",
  },
  {
    date: "5 Oktober 2026",
    hash: "9b5e6ff",
    branch: "feature/local-sprint",
    title: "Pengumuman Finalis",
    description: "Pengumuman finalis regional hackathon yang berhak melaju menuju babak final nasional.",
    author: "reviewer <semesta@sevima.com>",
    status: "STAGED",
  },
  {
    date: "24 – 25 Oktober 2026",
    hash: "0a7f8bb",
    branch: "main",
    title: "Interview Final",
    description: "Peserta terpilih mengikuti tahapan final tatap muka. Akomodasi ditanggung penuh oleh SEVIMA.",
    author: "c-level <board@sevima.com>",
    status: "UNRELEASED",
  },
  {
    date: "28 Oktober 2026",
    hash: "f8c2e7a",
    branch: "main",
    title: "Pengumuman Pemenang",
    description: "Pengumuman Awardee SEMESTA 8 dan penutupan acara. Grand celebration!",
    author: "exec <board@sevima.com>",
    status: "UNRELEASED",
  },
];
---

<section id="timeline" class="relative py-24 md:py-32 px-4 border-t border-dark-border/40 bg-dark-bg/30">
  <div class="max-w-4xl mx-auto">
    <!-- Header Block -->
    <div data-reveal="up" class="text-left border-l-2 border-terminal-purple pl-6 max-w-3xl mb-20 font-mono">
      <p class="text-xs uppercase tracking-widest text-terminal-purple mb-2">// HACK_SESSION: TIMELINE.log</p>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight text-text-primary uppercase">
        GIT COMMIT LOGS: <span class="text-transparent bg-clip-text bg-gradient-to-r from-terminal-purple to-terminal-cyan">ROADMAP</span>
      </h2>
      <p class="mt-4 text-sm text-text-muted max-w-xl font-sans normal-case">
        Telusuri cabang kode menuju kesuksesan. Ikuti setiap commit, kerjakan fiturnya, dan lakukan merge menuju panggung pemenang utama.
      </p>
    </div>

    <!-- Git-graph timeline -->
    <div class="relative space-y-0">
      {milestones.map((item, i) => {
        // We select colors based on branch
        const isMain = item.branch === "main";
        const branchColor = isMain ? "text-terminal-purple" : "text-terminal-cyan";
        const borderGlow = isMain ? "hover:border-terminal-purple/40" : "hover:border-terminal-cyan/40";
        
        return (
          <div class="timeline-item flex items-stretch min-h-[160px] group">
            <!-- Left Graph visual representation using SVG lines -->
            <div class="w-16 sm:w-24 flex-shrink-0 flex justify-center relative select-none">
              {/* Vertical line - main branch */}
              <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] bg-dark-border/80"></div>
              
              {/* Feature branch vertical line (starts at row 2, ends at row 4) */}
              {i >= 2 && i <= 3 && (
                <div class="absolute left-[calc(50%+20px)] top-0 bottom-0 w-[2px] bg-terminal-cyan/20"></div>
              )}
              
              {/* Visual Branch curve connectors */}
              {i === 2 && (
                <svg class="absolute top-0 left-1/2 -translate-x-1/2 w-8 h-12 text-terminal-cyan/30" viewBox="0 0 32 48" fill="none">
                  <path d="M16 0 C16 20, 28 20, 28 40" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
              {i === 4 && (
                <svg class="absolute -top-12 left-1/2 -translate-x-1/2 w-8 h-12 text-terminal-cyan/30" viewBox="0 0 32 48" fill="none">
                  <path d="M28 0 C28 20, 16 20, 16 40" stroke="currentColor" stroke-width="2" />
                </svg>
              )}

              {/* Commit node dot */}
              <div class={`absolute top-8 left-1/2 -translate-x-1/2 z-10 w-4.5 h-4.5 rounded-full bg-dark-bg border-2 ${isMain ? 'border-terminal-purple' : 'border-terminal-cyan'} flex items-center justify-center`}>
                <div class={`w-1.5 h-1.5 rounded-full ${isMain ? 'bg-terminal-purple' : 'bg-terminal-cyan'} group-hover:scale-125 transition-transform`}></div>
              </div>
            </div>

            <!-- Content Card (Styled like Git Commit block) -->
            <div class="flex-1 pb-10 pl-2">
              <div class={`code-card rounded-md p-5 border border-dark-border bg-dark-surface/50 font-mono text-left ${borderGlow}`}>
                <!-- Meta Info (Commit header) -->
                <div class="flex flex-wrap items-center justify-between gap-2 border-b border-dark-border/40 pb-2.5 mb-3 text-xs">
                  <div class="flex items-center gap-1.5">
                    <span class="text-terminal-yellow">commit {item.hash}</span>
                    <span class="text-text-muted">|</span>
                    <span class={branchColor}>ref: {item.branch}</span>
                  </div>
                  <span class="inline-block px-2 py-0.5 rounded bg-dark-card border border-dark-border text-[9px] text-text-muted">
                    {item.status}
                  </span>
                </div>

                <!-- Commit Details -->
                <div class="text-[11px] text-text-muted mb-2 space-y-0.5">
                  <p>Author: <span class="text-text-primary">{item.author}</span></p>
                  <p>Date: <span class="text-text-primary">{item.date}</span></p>
                </div>

                <h3 class="text-base font-bold text-text-primary mb-1 mt-3">
                  {item.title}
                </h3>
                <p class="text-xs text-text-muted leading-relaxed font-sans mt-2">
                  {item.description}
                </p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
