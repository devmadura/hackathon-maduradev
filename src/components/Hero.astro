---
// Hero.astro
import CountdownTimer from "./CountdownTimer.astro";
import TerminalConsole from "./TerminalConsole.astro";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 lg:px-8 cyber-grid overflow-hidden"
>
  <!-- Cybernetic tech graphics (Subtle layout borders and status lines) -->
  <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-terminal-cyan/20 to-transparent"></div>
  <div class="absolute inset-y-0 left-10 w-px bg-dark-border/20 hidden lg:block"></div>
  <div class="absolute inset-y-0 right-10 w-px bg-dark-border/20 hidden lg:block"></div>
  
  <!-- Glowing Background Orbs -->
  <div class="absolute inset-0 pointer-events-none z-0">
    <div class="absolute top-1/4 left-1/4 w-87.5 h-87.5 bg-terminal-cyan/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-75 h-75 bg-terminal-magenta/5 rounded-full blur-[90px]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto w-full grid lg:grid-cols-12 gap-12 items-center">
    <!-- Left Column: Branding, Tagline, & CTAs -->
    <div class="lg:col-span-7 flex flex-col items-start text-left">
      
      <!-- System Revision Badge -->
      <div 
        id="hero-badge" 
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded bg-dark-card border border-dark-border font-mono text-xs text-text-muted mb-6"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-terminal-yellow animate-ping"></span>
        <span class="text-terminal-yellow">SYS_REV: 8.0.0</span>
        <span class="text-dark-border">|</span>
        <span>STATUS: ACTIVE</span>
      </div>

      <!-- Glitch Title -->
      <h1 
        id="hero-title" 
        class="font-mono text-4xl sm:text-5xl md:text-6xl font-extrabold leading-[1.1] tracking-tight text-text-primary"
      >
        <span class="block text-text-muted text-lg sm:text-xl font-semibold mb-2">HACKATHON_EVENT:</span>
        <span class="glitch-text text-transparent bg-clip-text bg-linear-to-r from-terminal-cyan via-terminal-purple to-terminal-magenta" data-text="SEMESTA 8">SEMESTA 8</span>
      </h1>

      <!-- Subtitle -->
      <div 
        id="hero-sub" 
        class="mt-4 font-mono text-base sm:text-lg md:text-xl text-terminal-cyan flex items-center gap-2"
      >
        <span>[</span>
        <span>SEVIMA</span>
        <span class="text-terminal-magenta">×</span>
        <span>MaduraDev</span>
        <span>]</span>
      </div>

      <!-- Tagline -->
      <p 
        id="hero-tagline" 
        class="mt-6 text-sm sm:text-base text-text-muted max-w-xl leading-relaxed font-sans"
      >
        Platform bertemunya developer muda berbakat se-Indonesia. Bangun solusi inovatif pendidikan digital (EdTech), kembangkan keahlianmu, dan menangkan pendanaan eksklusif.
      </p>

      <!-- Countdown Wrapper -->
      <div class="mt-8 w-full max-w-md">
        <p class="font-mono text-[10px] text-terminal-yellow uppercase tracking-widest mb-2 flex items-center gap-1.5">
          <span class="animate-pulse">⏳</span> time_remaining_to_register.log
        </p>
        <div class="bg-dark-surface/50 border border-dark-border/40 p-4 rounded-lg md:ms-20">
          <CountdownTimer />
        </div>
      </div>

      <!-- Action Buttons -->
      <div id="hero-ctas" class="mt-8 flex flex-wrap gap-4">
        <button
          id="open-referral-modal"
          type="button"
          class="cyber-button cyber-button-cyan px-6 py-3 text-sm font-semibold"
        >
          [ EXEC_REGISTRATION ]
        </button>
        <a
          href="#about"
          class="cyber-button cyber-button-green px-6 py-3 text-sm font-semibold"
        >
          [ CAT_INFO_MD ]
        </a>
      </div>
    </div>

    <!-- Right Column: Interactive Terminal Simulator -->
    <div class="lg:col-span-5 w-full flex justify-center">
      <TerminalConsole />
    </div>
  </div>

  <!-- Tech status border at bottom -->
  <div class="absolute bottom-0 left-0 w-full bg-[#05050a] border-t border-dark-border py-2 px-4 flex items-center justify-between text-[9px] font-mono text-text-muted select-none">
    <span>LOC_COORD: 7.2575° S, 112.7521° E (MADURA)</span>
    <span class="hidden sm:inline">DB_CONNECT: OK | SYS_LOAD: 0.12</span>
    <span>MADURADEV // 2026</span>
  </div>

  <!-- Referral Code Modal -->
  <div
    id="referral-modal-overlay"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm px-4"
  >
    <div
      id="referral-modal"
      class="relative w-full max-w-md bg-dark-card border border-dark-border rounded-lg cyber-grid overflow-hidden"
    >
      <!-- top accent line -->
      <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-terminal-cyan/40 to-transparent"></div>

      <!-- close button -->
      <button
        id="close-referral-modal"
        type="button"
        aria-label="Close"
        class="absolute top-3 right-3 font-mono text-xs text-text-muted hover:text-terminal-magenta transition-colors"
      >
        [ X ]
      </button>

      <div class="p-6 sm:p-8 flex flex-col items-start text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded bg-dark-surface border border-dark-border font-mono text-xs text-text-muted mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-terminal-yellow animate-ping"></span>
          <span class="text-terminal-yellow">REFERRAL_CODE.DAT</span>
        </div>

        <h3 class="font-mono text-lg sm:text-xl font-bold text-text-primary mb-2">
          Gunakan kode referral sebelum daftar
        </h3>
        <p class="font-mono text-xs sm:text-sm text-text-muted mb-6 leading-relaxed">
          Salin kode di bawah ini, lalu tempel pada form pendaftaran untuk Madura.
        </p>

        <div class="w-full flex items-center justify-between gap-3 bg-dark-surface/70 border border-dark-border/60 rounded-lg px-4 py-3 mb-6">
          <code id="referral-code-text" class="font-mono text-lg sm:text-xl font-bold text-terminal-cyan tracking-widest select-all">
            MADURADEV
          </code>
          <button
            id="copy-referral-code"
            type="button"
            class="cyber-button cyber-button-green px-3 py-2 text-[11px] font-semibold whitespace-nowrap"
          >
            [ COPY ]
          </button>
        </div>

        <a
          id="proceed-registration-link"
          href="https://maukuliah.id/beasiswa-semesta"
          target="_blank"
          rel="noopener noreferrer"
          class="cyber-button cyber-button-cyan w-full text-center px-6 py-3 text-sm font-semibold"
        >
          [ PROCEED_TO_REGISTER ]
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const openBtn = document.getElementById("open-referral-modal");
  const closeBtn = document.getElementById("close-referral-modal");
  const overlay = document.getElementById("referral-modal-overlay");
  const copyBtn = document.getElementById("copy-referral-code");
  const codeText = document.getElementById("referral-code-text");
  const proceedLink = document.getElementById("proceed-registration-link");

  function openModal() {
    overlay?.classList.remove("hidden");
    overlay?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    overlay?.classList.add("hidden");
    overlay?.classList.remove("flex");
    document.body.style.overflow = "";
  }

  openBtn?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);

  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  copyBtn?.addEventListener("click", async () => {
    const code = codeText?.textContent?.trim() ?? "MADURADEV";
    try {
      await navigator.clipboard.writeText(code);
    } catch {
      const range = document.createRange();
      if (codeText) range.selectNodeContents(codeText);
      const selection = window.getSelection();
      selection?.removeAllRanges();
      selection?.addRange(range);
      document.execCommand("copy");
      selection?.removeAllRanges();
    }

    if (copyBtn) {
      const original = copyBtn.textContent;
      copyBtn.textContent = "[ COPIED! ]";
      setTimeout(() => {
        copyBtn.textContent = original;
      }, 1500);
    }
  });

  // Optional: close modal once user proceeds to registration
  proceedLink?.addEventListener("click", () => {
    setTimeout(closeModal, 300);
  });
</script>