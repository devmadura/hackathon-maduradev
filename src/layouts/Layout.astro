---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SEMESTA 8 — Sevima × Madura.dev Hackathon",
  description = "Hackathon SEMESTA 8 oleh Sevima × Madura.dev. Daftarkan dirimu dan jadi bagian dari revolusi teknologi Indonesia!",
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050509" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />

    <!-- GSAP via import map so public scripts can use ES imports -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
    <script>
      // Reduced motion check — run early before GSAP loads
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("reduced-motion");
      }
    </script>
    <script src="/animations.js" defer></script>
  </body>
</html>
